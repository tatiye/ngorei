         "node_modules/tatiye/ngorei.css",
         "node_modules/tatiye/ngorei.min.js",
         "lib/prism/prism.css"
      ],
      "footer":[ 
         "lib/jquery/jquery.min.js",
         "lib/jquery/jquery-ui.min.js",
         "lib/js-cookie/js.cookie.js",
         "lib/prism/prism.js",
         "lib/prism/clipboard.code.js",
         "lib/prism/clipboard.min.js",
         "lib/shortcuts.js"
      ]
   },

   "navbar":{
