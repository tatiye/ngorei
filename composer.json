{
    "name": "tatiye/ngorei",
    "description": "Bangun aplikasi iOS, Android & Desktop berfitur lengkap",
    "homepage": "https://tatiye.net",
    "keywords": ["mvc", "framework", "lite"],
    "license": "MIT",
    "type": "project",
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
          "app\\": "app/helpers/",
          "app\\config\\": "app/config/",
          "app\\models\\": "app/models/",
          "public\\": "public/"
        }
    },
    "authors": [
        {
            "name": "tatiye",
            "email": "info@tatiye.net"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
         "php": "^7.3|^8.0",
         "doctrine/sql-formatter": "^1.1",
         "phpoffice/phpspreadsheet": "^1.29",
         "dompdf/dompdf": "^2.0",
         "midtrans/midtrans-php": "dev-master"
    },

    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }

}
