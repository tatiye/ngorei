{
    "name": "tatiye/ngorei",
    "description": "Bangun aplikasi iOS, Android & Desktop berfitur lengkap",
    "homepage": "https://madskullcreations.com",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
          "app\\": "app/helpers/",
          "app\\config\\": "app/config/",
          "app\\models\\": "app/models/",
          "public\\": "public/"
        }
    },
    "authors": [
        {
            "name": "tatiye",
            "email": "info@tatiye.net"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
         "php": "^7.4|^8.0",
         "doctrine/sql-formatter": "^1.1",
         "phpoffice/phpspreadsheet": "^1.29",
         "dompdf/dompdf": "^2.0",
         "midtrans/midtrans-php": "dev-master"
    },


    "scripts": {
        "post-install-cmd": ["App\\Console\\Installer::postInstall", "App\\Console\\InstallerSimplicity::postInstall"],
        "post-create-project-cmd": ["App\\Console\\Installer::postInstall", "App\\Console\\InstallerSimplicity::postInstall"],
        "post-update-cmd": ["App\\Console\\InstallerSimplicity::postInstall"],
        "post-autoload-dump": "Cake\\Composer\\Installer\\PluginInstaller::postAutoloadDump",
        "check": [
            "@test",
            "@cs-check"
        ],
        "cs-check": "phpcs --colors -p --standard=vendor/cakephp/cakephp-codesniffer/CakePHP ./src ./tests",
        "cs-fix": "phpcbf --colors --standard=vendor/cakephp/cakephp-codesniffer/CakePHP ./src ./tests",
        "test": "phpunit --colors=always"
    },
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }

}
